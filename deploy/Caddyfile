# Reverse proxy for Twenty.
#
# Before a domain is mounted: SITE_ADDRESS=:80  -> plain HTTP on the reserved IP.
# After GoDaddy A-record points at the reserved IP: set
#   SITE_ADDRESS=crm.yourdomain.com  and  ACME_EMAIL=ops@totssy.com  in .env
# and Caddy will obtain + renew a Let's Encrypt cert automatically on :443.

{
	email {$ACME_EMAIL}
}

{$SITE_ADDRESS::80} {
	reverse_proxy server:3000
}
