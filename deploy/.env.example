# ---- The Rift / Twenty — runtime environment ----
# Copy to `.env` on the droplet and fill in. NEVER commit the real `.env`.

TAG=prod

# Public URL Twenty is served at.
#   start:           http://<reserved-ip>
#   domain mounted:  https://crm.yourdomain.com
SERVER_URL=http://REPLACE_WITH_RESERVED_IP

# --- Caddy reverse proxy ---
# Start with :80 (plain HTTP). Switch to the FQDN for automatic HTTPS.
SITE_ADDRESS=:80
ACME_EMAIL=ops@totssy.com

# --- Managed Postgres ---
# From the rift-infra output:  tofu output -raw postgres_private_uri
# Keep sslmode=require; DO uses its own CA so allow self-signed.
PG_DATABASE_URL=postgres://twenty:PASSWORD@PRIVATE_HOST:25060/twenty?sslmode=require
PG_SSL_ALLOW_SELF_SIGNED=true

# --- Redis (local container) ---
REDIS_URL=redis://redis:6379

# --- Secrets ---  generate with: openssl rand -base64 32
ENCRYPTION_KEY=REPLACE_ME
# FALLBACK_ENCRYPTION_KEY=   # set to the previous ENCRYPTION_KEY only during a key rotation

# --- File storage ---
# v1: local volume (shared server+worker, persisted via docker volume).
STORAGE_TYPE=local
#
# v2 (once Spaces keys are minted): switch to S3 and fill these in.
# STORAGE_TYPE=s3
# STORAGE_S3_REGION=fra1
# STORAGE_S3_NAME=rift-prod-twenty-storage
# STORAGE_S3_ENDPOINT=https://fra1.digitaloceanspaces.com
# STORAGE_S3_ACCESS_KEY_ID=REPLACE_ME
# STORAGE_S3_SECRET_ACCESS_KEY=REPLACE_ME
